{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/xtmon-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "StoredProcedureLogging": {
    "ConnectionStringName": "LogFiAlmt",
    "StoredProcedure": "monitoring.UspInsertAPSActionsLog",
    "CommandTimeoutSeconds": 5
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "LogFiAlmt": "Server=10.211.55.2,1433;Database=LOG_FI_ALMT;User Id=sa;Password=DockerPassword123!;TrustServerCertificate=True;",
    "StagingFiAlmt": "Server=10.211.55.2,1433;Database=STAGING_FI_ALMT;User Id=sa;Password=DockerPassword123!;TrustServerCertificate=True;",
    "Publication": "Server=10.211.55.2,1433;Database=PUBLICATION;User Id=sa;Password=DockerPassword123!;TrustServerCertificate=True;",
    "DtmFi": "Server=10.211.55.2,1433;Database=DTM_FI;User Id=sa;Password=DockerPassword123!;TrustServerCertificate=True;",
    "MainUam": "Server=10.211.55.2,1433;Database=MAIN_UAM;User Id=sa;Password=DockerPassword123!;TrustServerCertificate=True;"
  },
  "UamAuthorization": {
    "ConnectionStringName": "MainUam",
    "GetAdminUserStoredProcedure": "[uam].[UspGetAdminUserByBnpId]",
    "CommandTimeoutSeconds": 30
  },
  "Monitoring": {
    "DbSizePlusDiskStoredProcedure": "monitoring.UspGetDbSizePlusDisk",
    "DbBackupsStoredProcedure": "monitoring.UspGetDBBackups",
    "CommandTimeoutSeconds": 30
  },
  "ReplayFlows": {
    "ConnectionStringName": "StagingFiAlmt",
    "GetFailedFlowsStoredProcedure": "Replay.UspGetFailedFlows",
    "ReplayFlowsStoredProcedure": "Replay.UspInsertReplayFlows",
    "ReplayFlowsTableTypeName": "Replay.ReplayAdjAtCoreSet",
    "ProcessReplayFlowsStoredProcedure": "Replay.UspProcessReplayFlows",
    "GetReplayFlowStatusStoredProcedure": "Replay.UspGetReplayFlowStatus",
    "GetReplayFlowProcessStatusStoredProcedure": "Replay.UspGetReplayFlowProcessStatus",
    "CommandTimeoutSeconds": 30,
    "ProcessCommandTimeoutSeconds": 3600,
    "StatusPollIntervalSeconds": 15
  },
  "JvCalculation": {
    "PnlDatesConnectionStringName": "StagingFiAlmt",
    "PublicationConnectionStringName": "Publication",
    "GetPnlDatesStoredProcedure": "replay.UspGetPnlDates",
    "CheckJvCalculationStoredProcedure": "monitoring.UspCheckJvCalculation",
    "DtmFiConnectionStringName": "DtmFi",
    "FixJvCalculationStoredProcedure": "Administration.UspCleanUpJvissue",
    "JobConnectionStringName": "LogFiAlmt",
    "JobEnqueueStoredProcedure": "monitoring.UspJvJobEnqueue",
    "JobTakeNextStoredProcedure": "monitoring.UspJvJobTakeNext",
    "JobHeartbeatStoredProcedure": "monitoring.UspJvJobHeartbeat",
    "JobSaveResultStoredProcedure": "monitoring.UspJvJobSaveResult",
    "JobMarkCompletedStoredProcedure": "monitoring.UspJvJobMarkCompleted",
    "JobMarkFailedStoredProcedure": "monitoring.UspJvJobMarkFailed",
    "JobGetByIdStoredProcedure": "monitoring.UspJvJobGetById",
    "JobGetLatestStoredProcedure": "monitoring.UspJvJobGetLatestByUserPnlDate",
    "JobExpireStaleStoredProcedure": "monitoring.UspJvJobExpireStale",
    "CommandTimeoutSeconds": 30,
    "Precision": 0.01,
    "JobPollIntervalSeconds": 5,
    "JobRunningStaleTimeoutSeconds": 900
  }
}