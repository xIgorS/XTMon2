<details class="group flex flex-col gap-1" open="@IsOpen">
    <summary class="nav-link list-none justify-between @(IsOpen ? "nav-link-active" : string.Empty)">
        <span class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h10.5m-10.5 4.5h16.5m-16.5 4.5h10.5M15 5.25l6 6-6 6" />
            </svg>
            Functional Rejection
        </span>
        <svg xmlns="http://www.w3.org/2000/svg"
             fill="none"
             viewBox="0 0 24 24"
             stroke-width="1.5"
             stroke="currentColor"
             class="h-4 w-4 shrink-0 transition-transform group-open:rotate-90">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
    </summary>
    <div class="submenu-group">
        @if (isLoading)
        {
            <span class="submenu-link" aria-live="polite">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5 shrink-0">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2.25M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                Loading...
            </span>
        }
        else if (!string.IsNullOrWhiteSpace(loadError))
        {
            <span class="submenu-link text-error" aria-live="polite">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5 shrink-0">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.007v.008H12v-.008ZM10.29 3.86 1.82 18a1.875 1.875 0 0 0 1.607 2.812h16.946A1.875 1.875 0 0 0 21.98 18L13.51 3.86a1.875 1.875 0 0 0-3.22 0Z" />
                </svg>
                Unable to load menu
            </span>
            <button type="button" class="submenu-link" @onclick="LoadMenuItemsAsync">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5 shrink-0">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" />
                </svg>
                Retry
            </button>
        }
        else if (menuItems.Count == 0)
        {
            <span class="submenu-link muted">No items available.</span>
        }
        else
        {
            @foreach (var item in menuItems)
            {
                <a class="@GetSubmenuLinkClass(item)"
                   href="@GetItemHref(item)"
                   title="@item.SourceSystemBusinessDataTypeCode">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-3.5 w-3.5 shrink-0">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5h7.5A2.25 2.25 0 0 1 18 6.75v10.5A2.25 2.25 0 0 1 15.75 19.5h-7.5A2.25 2.25 0 0 1 6 17.25V6.75A2.25 2.25 0 0 1 8.25 4.5Z" />
                    </svg>
                    @item.SourceSystemBusinessDataTypeCode
                </a>
            }
        }
    </div>
</details>