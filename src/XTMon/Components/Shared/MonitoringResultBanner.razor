@if (Truncated || HasPersistedJob)
{
    <div class="mb-4 flex flex-col gap-3 rounded-2xl border border-sky-500/20 bg-sky-500/5 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            @if (Truncated)
            {
                <p class="text-sm font-semibold text-heading">Showing first @PersistedRowCount of @TotalRowCount rows.</p>
                <p class="mt-1 text-sm muted">The complete persisted result is available as a CSV export.</p>
            }
            else if (HasPersistedJob)
            {
                <p class="text-sm muted">A CSV export is available for the persisted result shown on this page.</p>
            }
        </div>

        @if (HasPersistedJob && !string.IsNullOrWhiteSpace(ExportUrl))
        {
            <a class="primary-button" href="@ExportUrl">Download CSV</a>
        }
    </div>
}

@code {
    [Parameter]
    public bool Truncated { get; set; }

    [Parameter]
    public int PersistedRowCount { get; set; }

    [Parameter]
    public int TotalRowCount { get; set; }

    [Parameter]
    public bool HasPersistedJob { get; set; }

    [Parameter]
    public string? ExportUrl { get; set; }
}