@page "/system-diagnostics"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "UamRestricted")]

<PageTitle>System Diagnostics</PageTitle>

<div class="space-y-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="section-label">Deployment verification</p>
            <h1 class="text-2xl font-bold text-heading mt-1">System Diagnostics</h1>
            <p class="muted mt-1">Checks database connections and stored procedure signatures for monitoring, pricing validation, out-of-scope portfolio, missing SOG check, adjustment links check, column store check, trading vs Fivr check, mirrorization, result transfer, rollovered portfolios, sas tables, non XTG portfolio, rejected XTG portfolio, feedout extraction, future cash, fact PV/CA consistency, multiple feed version, replay flows, JV calculation, logging, and UAM authorization.</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
            <button class="rounded-xl border border-rose-300 bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-700 transition hover:bg-rose-100 disabled:cursor-not-allowed disabled:opacity-60"
                    @onclick="CancelAllBackgroundJobsAsync"
                    disabled="@isCancellingAllJobs">
                @(isCancellingAllJobs ? "Cancelling all jobs..." : "Cancel All Background Jobs")
            </button>
            <button class="primary-button-filled" @onclick="RunCheckAsync" disabled="@isRunning">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 1 0 12.728 12.728M5.636 5.636a9 9 0 1 1 12.728 12.728M5.636 5.636 12 12m0 0 6.364-6.364" />
                </svg>
                @(isRunning ? "Running checks..." : (report is null ? "Run Diagnostics" : "Re-run Diagnostics"))
            </button>
        </div>
    </div>

    <div class="surface !border-slate-200/80">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <p class="section-label">Operational controls</p>
                <h2 class="mt-1 text-lg font-bold text-heading">Global background job stop</h2>
                <p class="muted mt-1 text-sm">Stops all active monitoring and JV background jobs, requests cancellation for any in-memory workers, and verifies that queued or running rows are no longer active.</p>
            </div>
            <span class="pill text-xs shrink-0">Affects monitoring and JV jobs</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(bulkCancellationMessage))
        {
            <div class="mt-4 rounded-2xl border px-4 py-3 @(bulkCancellationIsError ? "border-rose-500/30 bg-rose-50/80 text-rose-700" : "border-emerald-500/30 bg-emerald-50/80 text-emerald-700")">
                <p class="text-sm font-semibold">@(bulkCancellationIsError ? "Bulk cancellation failed" : "Bulk cancellation summary")</p>
                <p class="mt-1 text-sm">@bulkCancellationMessage</p>
            </div>
        }
    </div>

    <div class="surface !border-sky-200/80">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <p class="section-label">Startup Recovery</p>
                <h2 class="mt-1 text-lg font-bold text-heading">Reset orphaned running statuses</h2>
                <p class="muted mt-1 text-sm">Runs the same recovery used on application startup: any monitoring or JV job row still marked <strong>Running</strong> is treated as orphaned and moved out of the running state so the UI and queues can recover cleanly.</p>
            </div>
            <span class="pill text-xs shrink-0">Matches startup behavior</span>
        </div>

        <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center">
            <button class="rounded-xl border border-sky-300 bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-700 transition hover:bg-sky-100 disabled:cursor-not-allowed disabled:opacity-60"
                    @onclick="RecoverStartupJobsAsync"
                    disabled="@(isRecoveringStartupJobs || isCancellingAllJobs || isRunning)">
                @(isRecoveringStartupJobs ? "Resetting running statuses..." : "Reset Running Statuses")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(recoveryMessage))
        {
            <div class="mt-4 rounded-2xl border px-4 py-3 @(recoveryIsError ? "border-rose-500/30 bg-rose-50/80 text-rose-700" : "border-emerald-500/30 bg-emerald-50/80 text-emerald-700")">
                <p class="text-sm font-semibold">@(recoveryIsError ? "Recovery failed" : "Recovery summary")</p>
                <p class="mt-1 text-sm">@recoveryMessage</p>
            </div>
        }
    </div>

    <div class="surface !border-amber-200/80">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <p class="section-label">Stuck Jobs</p>
                <h2 class="mt-1 text-lg font-bold text-heading">Background jobs with silent workers</h2>
                <p class="muted mt-1 text-sm">Shows monitoring, JV, and replay rows currently in an Active state whose worker has not reported activity recently. Use Force-Expire to mark any stuck rows as failed so the menu can return to a green state; in-memory workers, if still alive, will observe the DB change on their next heartbeat cycle and stop.</p>
            </div>
            <span class="pill text-xs shrink-0">Escape hatch</span>
        </div>

        <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center">
            <button class="rounded-xl border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-700 transition hover:bg-amber-100 disabled:cursor-not-allowed disabled:opacity-60"
                    @onclick="LoadStuckJobsAsync"
                    disabled="@(isLoadingStuckJobs || isForceExpiring)">
                @(isLoadingStuckJobs ? "Loading stuck jobs..." : (stuckJobsReport is null ? "Load Stuck Jobs" : "Refresh Stuck Jobs"))
            </button>
            <button class="rounded-xl border border-rose-300 bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-700 transition hover:bg-rose-100 disabled:cursor-not-allowed disabled:opacity-60"
                    @onclick="ForceExpireStuckJobsAsync"
                    disabled="@(isForceExpiring || isLoadingStuckJobs)">
                @(isForceExpiring ? "Force-expiring..." : "Force-Expire All Stuck Jobs")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(stuckJobsMessage))
        {
            <div class="mt-4 rounded-2xl border px-4 py-3 @(stuckJobsIsError ? "border-rose-500/30 bg-rose-50/80 text-rose-700" : "border-emerald-500/30 bg-emerald-50/80 text-emerald-700")">
                <p class="text-sm font-semibold">@(stuckJobsIsError ? "Stuck jobs action failed" : "Stuck jobs summary")</p>
                <p class="mt-1 text-sm">@stuckJobsMessage</p>
            </div>
        }

        @if (stuckJobsReport is not null && stuckJobsReport.TotalStuckCount > 0)
        {
            <div class="mt-4 space-y-4">
                @if (stuckJobsReport.StuckMonitoringJobs.Count > 0)
                {
                    <div>
                        <p class="stat-label">Stuck Monitoring Jobs (@stuckJobsReport.StuckMonitoringJobs.Count)</p>
                        <div class="db-grid__wrap mt-2">
                            <table class="db-grid">
                                <thead>
                                    <tr>
                                        <th class="db-grid__head db-grid__cell--text">Job</th>
                                        <th class="db-grid__head db-grid__cell--text">Category / Submenu</th>
                                        <th class="db-grid__head db-grid__cell--text">PnlDate</th>
                                        <th class="db-grid__head db-grid__cell--text">Status</th>
                                        <th class="db-grid__head db-grid__cell--text">Last Heartbeat (UTC)</th>
                                        <th class="db-grid__head db-grid__cell--text">Worker</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var job in stuckJobsReport.StuckMonitoringJobs)
                                    {
                                        <tr class="db-grid__row">
                                            <td class="db-grid__cell db-grid__cell--text font-mono text-xs">#@job.JobId</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@job.Category / @job.SubmenuKey</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@job.PnlDate.ToString("yyyy-MM-dd")</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@job.Status</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@(job.LastHeartbeatAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@(job.WorkerId ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                @if (stuckJobsReport.StuckJvJobs.Count > 0)
                {
                    <div>
                        <p class="stat-label">Stuck JV Jobs (@stuckJobsReport.StuckJvJobs.Count)</p>
                        <div class="db-grid__wrap mt-2">
                            <table class="db-grid">
                                <thead>
                                    <tr>
                                        <th class="db-grid__head db-grid__cell--text">Job</th>
                                        <th class="db-grid__head db-grid__cell--text">User</th>
                                        <th class="db-grid__head db-grid__cell--text">PnlDate</th>
                                        <th class="db-grid__head db-grid__cell--text">Request</th>
                                        <th class="db-grid__head db-grid__cell--text">Status</th>
                                        <th class="db-grid__head db-grid__cell--text">Last Heartbeat (UTC)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var job in stuckJobsReport.StuckJvJobs)
                                    {
                                        <tr class="db-grid__row">
                                            <td class="db-grid__cell db-grid__cell--text font-mono text-xs">#@job.JobId</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@job.UserId</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@job.PnlDate.ToString("yyyy-MM-dd")</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@job.RequestType</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@job.Status</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@(job.LastHeartbeatAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                @if (stuckJobsReport.StuckReplayBatches.Count > 0)
                {
                    <div>
                        <p class="stat-label">Stuck Replay Batches (@stuckJobsReport.StuckReplayBatches.Count)</p>
                        <div class="db-grid__wrap mt-2">
                            <table class="db-grid">
                                <thead>
                                    <tr>
                                        <th class="db-grid__head db-grid__cell--text">FlowId</th>
                                        <th class="db-grid__head db-grid__cell--text">PnlDate</th>
                                        <th class="db-grid__head db-grid__cell--text">CreatedBy</th>
                                        <th class="db-grid__head db-grid__cell--text">DateStarted</th>
                                        <th class="db-grid__head db-grid__cell--text">ReplayStatus</th>
                                        <th class="db-grid__head db-grid__cell--text">Age (s)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var batch in stuckJobsReport.StuckReplayBatches)
                                    {
                                        <tr class="db-grid__row">
                                            <td class="db-grid__cell db-grid__cell--text font-mono text-xs">@batch.FlowId</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@batch.PnlDate.ToString("yyyy-MM-dd")</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@(batch.CreatedBy ?? "—")</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@(batch.DateStarted?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@(batch.ReplayStatus ?? "—")</td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">@batch.AgeSeconds</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if (ShowCleanupButtons)
    {
        <div class="surface !border-amber-200/80">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <div>
                    <p class="section-label">Maintenance</p>
                    <h2 class="mt-1 text-lg font-bold text-heading">LOG database cleanup</h2>
                    <p class="muted mt-1 text-sm">Clean Logging deletes APS Actions application log rows. Clean History deletes monitoring and JV orchestration history stored in the LOG database. History cleanup is blocked while any monitoring or JV job is queued or running.</p>
                </div>
                <span class="pill text-xs shrink-0">Hidden unless enabled in config</span>
            </div>

            <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center">
                <button class="rounded-xl border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-700 transition hover:bg-amber-100 disabled:cursor-not-allowed disabled:opacity-60"
                        @onclick="CleanLoggingAsync"
                        disabled="@(isCleaningLogging || isCleaningHistory)">
                    @(isCleaningLogging ? "Cleaning logging..." : "Clean Logging")
                </button>
                <button class="rounded-xl border border-rose-300 bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-700 transition hover:bg-rose-100 disabled:cursor-not-allowed disabled:opacity-60"
                        @onclick="CleanHistoryAsync"
                        disabled="@(isCleaningHistory || isCleaningLogging)">
                    @(isCleaningHistory ? "Cleaning history..." : "Clean History")
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(cleanupMessage))
            {
                <div class="mt-4 rounded-2xl border px-4 py-3 @(cleanupIsError ? "border-rose-500/30 bg-rose-50/80 text-rose-700" : "border-emerald-500/30 bg-emerald-50/80 text-emerald-700")">
                    <p class="text-sm font-semibold">@(cleanupIsError ? "Cleanup failed" : "Cleanup summary")</p>
                    <p class="mt-1 text-sm">@cleanupMessage</p>
                </div>
            }
        </div>
    }

    <div class="surface">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
            <div>
                <p class="section-label">Monitoring Job Capacity</p>
                <h2 class="mt-1 text-lg font-bold text-heading">Worker slot policy</h2>
                <p class="muted mt-1 text-sm">These limits are loaded from configuration at startup and control how many monitoring jobs can run in parallel. Update appsettings and restart the application to change them.</p>
            </div>
            <span class="pill text-xs shrink-0">Global max: @EffectiveMonitoringJobConcurrencyPolicy.GlobalLimit slot@(EffectiveMonitoringJobConcurrencyPolicy.GlobalLimit == 1 ? string.Empty : "s")</span>
        </div>

        <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-slate-200/70 bg-slate-50/80 p-4 dark:border-slate-700/70 dark:bg-slate-900/30">
                <p class="stat-label">Global Worker Pool</p>
                <p class="mt-2 text-2xl font-bold text-heading">@EffectiveMonitoringJobConcurrencyPolicy.GlobalLimit</p>
                <p class="muted mt-1 text-xs">Maximum monitoring jobs that can run at once across all menus.</p>
            </div>

            @foreach (var categoryLimit in EffectiveMonitoringJobConcurrencyPolicy.CategoryLimits)
            {
                <div class="rounded-2xl border border-slate-200/70 bg-slate-50/80 p-4 dark:border-slate-700/70 dark:bg-slate-900/30">
                    <p class="stat-label">@categoryLimit.DisplayName</p>
                    <p class="mt-2 text-2xl font-bold text-heading">@categoryLimit.EffectiveLimit</p>
                    <p class="muted mt-1 text-xs">@categoryLimit.Description</p>
                </div>
            }

            <div class="rounded-2xl border border-slate-200/70 bg-slate-50/80 p-4 dark:border-slate-700/70 dark:bg-slate-900/30">
                <p class="stat-label">Operational Note</p>
                <p class="mt-2 text-sm font-semibold text-heading">Free slots follow the caps</p>
                <p class="muted mt-1 text-xs">A category that reaches its own limit will wait even if the global pool still has free slots. Categories without a specific cap can use the remaining global capacity.</p>
            </div>
        </div>
    </div>

    @if (isRunning)
    {
        <div class="surface">
            <p class="muted">Connecting to all databases and verifying stored procedures...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(runError))
    {
        <div class="surface !border-rose-500/30">
            <p class="text-sm font-semibold text-error">Diagnostics failed to run.</p>
            <p class="mt-2 text-sm text-error/80">@runError</p>
        </div>
    }
    else if (report is null)
    {
        <div class="surface">
            <p class="muted">Click <strong>Run Diagnostics</strong> to verify all database connections and stored procedures, including Pricing, Pricing File Reception, Out of Scope Portfolio, Missing SOG Check, Adjustment Links Check, Column Store Check, Trading vs Fivr Check, Mirrorization, Result Transfer, Rollovered Portfolios, Sas tables, Non XTG Portfolio, Rejected XTG Portfolio, FeedOut Extraction, Future Cash, Fact PV/CA Consistency, Multiple Feed Version, Daily Balance, and Adjustments data-validation checks.</p>
        </div>
    }
    else
    {
        <div class="surface">
            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                <div>
                    <p class="stat-label">Coverage</p>
                    <p class="mt-1 text-sm text-heading">Monitoring and validation stack</p>
                    <p class="muted mt-1 text-xs">Database Space, Database Backups, Pricing, Pricing File Reception, Out of Scope Portfolio, Missing SOG Check, Adjustment Links Check, Column Store Check, Trading vs Fivr Check, Mirrorization, Result Transfer, Rollovered Portfolios, Sas tables, Non XTG Portfolio, Rejected XTG Portfolio, FeedOut Extraction, Future Cash, Fact PV/CA Consistency, Multiple Feed Version, Daily Balance, Adjustments, Replay Flows, JV Calculation, and UAM authorization.</p>
                </div>
                <div>
                    <p class="stat-label">What Is Verified</p>
                    <p class="mt-1 text-sm text-heading">Connection and signature health</p>
                    <p class="muted mt-1 text-xs">Each configured connection string is opened and every required stored procedure is checked for existence and parameter metadata.</p>
                </div>
                <div>
                    <p class="stat-label">When To Use It</p>
                    <p class="mt-1 text-sm text-heading">Before troubleshooting results</p>
                    <p class="muted mt-1 text-xs">Run diagnostics first when a screen fails to load, returns unexpected metadata, or appears misconfigured after a deployment.</p>
                </div>
            </div>
        </div>

        @* Summary banner *@
        <div class="surface @(report.AllPassed ? "!border-emerald-500/40" : "!border-rose-500/40")">
            <div class="flex items-center gap-3">
                @if (report.AllPassed)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-emerald-500 shrink-0">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    <div>
                        <p class="text-sm font-semibold text-emerald-500">All checks passed</p>
                        <p class="muted text-xs mt-0.5">@report.Databases.Count databases · @report.Databases.SelectMany(d => d.StoredProcedures).Count() stored procedures — all OK</p>
                    </div>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-error shrink-0">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                    </svg>
                    <div>
                        <p class="text-sm font-semibold text-error">@report.IssueCount @(report.IssueCount == 1 ? "issue" : "issues") found</p>
                        <p class="muted text-xs mt-0.5">@report.Databases.Count databases · @report.Databases.SelectMany(d => d.StoredProcedures).Count() stored procedures checked</p>
                    </div>
                }
                <p class="muted text-xs ml-auto shrink-0">@report.GeneratedAt.ToString("dd-MM-yyyy HH:mm:ss")</p>
            </div>
        </div>

        @* Per-database cards *@
        <div class="space-y-4">
            @foreach (var db in report.Databases)
            {
                var dbOk = db.Connected && db.StoredProcedures.All(sp => sp.Exists && sp.Error is null);
                <div class="surface">
                    @* Database header *@
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 icon-accent shrink-0">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                            </svg>
                            <div>
                                <h3 class="text-base font-bold text-heading">@db.ConnectionStringName</h3>
                                @if (db.Connected && db.DatabaseName is not null)
                                {
                                    <p class="muted text-xs">@db.ServerName · @db.DatabaseName · @FormatDuration(db.Duration)</p>
                                }
                                else if (!db.Connected)
                                {
                                    <p class="text-xs text-error/80 mt-0.5">@db.ConnectionError</p>
                                }
                            </div>
                        </div>
                        <span class="pill @(db.Connected ? (dbOk ? "text-emerald-500" : "text-amber-500") : "text-error") text-xs shrink-0">
                            @if (!db.Connected)
                            {
                                <text>Connection failed</text>
                            }
                            else if (dbOk)
                            {
                                <text>OK</text>
                            }
                            else
                            {
                                var spIssues = db.StoredProcedures.Count(sp => !sp.Exists || sp.Error is not null);
                                <text>@spIssues @(spIssues == 1 ? "issue" : "issues")</text>
                            }
                        </span>
                    </div>

                    @* Stored procedures table *@
                    @if (db.Connected && db.StoredProcedures.Count > 0)
                    {
                        <div class="db-grid__wrap mt-4">
                            <table class="db-grid">
                                <thead>
                                    <tr>
                                        <th class="db-grid__head db-grid__cell--text">Stored Procedure</th>
                                        <th class="db-grid__head db-grid__cell--status">Status</th>
                                        <th class="db-grid__head db-grid__cell--text">Parameters</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sp in db.StoredProcedures)
                                    {
                                        var spOk = sp.Exists && sp.Error is null;
                                        <tr class="db-grid__row">
                                            <td class="db-grid__cell db-grid__cell--text font-mono text-xs">@sp.FullName</td>
                                            <td class="db-grid__cell db-grid__cell--status">
                                                @if (sp.Error is not null)
                                                {
                                                    <span class="alert-badge alert-critical" title="@sp.Error">Error</span>
                                                }
                                                else if (sp.Exists)
                                                {
                                                    <span class="alert-badge alert-ok">Found</span>
                                                }
                                                else
                                                {
                                                    <span class="alert-badge alert-critical">Missing</span>
                                                }
                                            </td>
                                            <td class="db-grid__cell db-grid__cell--text text-xs">
                                                @if (sp.Parameters.Count == 0 && sp.Exists)
                                                {
                                                    <span class="muted">no parameters</span>
                                                }
                                                else if (sp.Parameters.Count > 0)
                                                {
                                                    <span class="font-mono">@FormatParameters(sp.Parameters)</span>
                                                }
                                                else if (sp.Error is not null)
                                                {
                                                    <span class="text-error/70 text-xs">@sp.Error</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (!db.Connected)
                    {
                        <p class="muted mt-3 text-sm">Stored procedure checks skipped — connection failed.</p>
                    }
                </div>
            }
        </div>
    }
</div>
