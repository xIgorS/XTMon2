@page "/monitoring"
@rendermode InteractiveServer

<PageTitle>Database Space</PageTitle>

<div class="space-y-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="section-label">Database monitoring</p>
            <h1 class="text-2xl font-bold text-heading mt-1">Database Space</h1>
            <p class="muted mt-1">Procedure: @FullyQualifiedProcedureName</p>
        </div>
        <button class="primary-button-filled" @onclick="ReloadAsync" disabled="@isLoading">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" />
            </svg>
            @(isLoading ? "Refreshing..." : "Refresh data")
        </button>
    </div>

	<div class="surface space-y-4">
		<div class="flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
			<div>
				<p class="section-label">XTarget DB Allocated Space</p>
				<h2 class="text-xl font-bold text-heading mt-1">Allocated Space by Metier</h2>
				<p class="muted mt-1">Source: [monitoring].[UspGetDBBackups] (SpaceAllocatedMB, grouped by database).</p>
			</div>
			<p class="muted">Last refresh: @(overviewLastRefresh?.ToString("dd-MM-yyyy HH:mm:ss") ?? "Not loaded")</p>
		</div>

		@if (isLoading && overviewLastRefresh is null)
		{
			<div class="surface">
				<p class="muted">Loading backup space data...</p>
			</div>
		}
		else if (!string.IsNullOrWhiteSpace(overviewLoadError))
		{
			<div class="surface !border-rose-500/30">
				<p class="text-sm font-semibold text-error">Failed to load backup space overview.</p>
				<p class="mt-2 text-sm text-error">@overviewLoadError</p>
			</div>
		}
		else
		{
			<div class="grid gap-4 md:grid-cols-2">
				@foreach (var chart in new[] { fiChart, gecdChart })
				{
					<div class="stat-card">
						<div class="flex items-center justify-between gap-3">
							<div>
								<p class="stat-label">Metier</p>
								<p class="text-2xl font-bold text-heading mt-1">@chart.DisplayName</p>
							</div>
							<p class="pill">Total: @FormatSpaceMb(chart.Total)</p>
						</div>

						@if (!chart.HasData)
						{
							<p class="muted mt-4">No SpaceAllocatedMB rows found for @chart.DisplayName.</p>
						}
						else
						{
							<div class="mt-4 flex flex-col gap-4 lg:flex-row lg:items-center">
								<div class="relative shrink-0 rounded-full" style="@($"{chart.ChartStyle} width: 10rem; height: 10rem;")">
									<div class="absolute rounded-full" style="inset: 2rem; background-color: var(--bg-surface);"></div>
								</div>
								<div class="flex-1 space-y-3">
									@foreach (var slice in chart.Slices)
									{
										<div class="flex items-center justify-between gap-3 text-sm">
											<div class="flex items-center gap-2">
													<span class="h-3.5 w-3.5 rounded-full shrink-0" style="background-color: @slice.Color; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.35);"></span>
												<span class="text-heading">@slice.Label</span>
											</div>
											<span class="muted shrink-0">@ToPercent(slice.Value, chart.Total) · @FormatSpaceMb(slice.Value)</span>
										</div>
									}
								</div>
							</div>
						}
					</div>
				}
			</div>
		}
	</div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="stat-card">
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <p class="stat-label">Last refresh</p>
            <p class="stat-value">@(lastRefresh?.ToString("dd-MM-yyyy HH:mm:ss") ?? "Not loaded")</p>
            <p class="muted mt-1">Local time</p>
        </div>
        <div class="stat-card">
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
            </svg>
            <p class="stat-label">Rows</p>
            <p class="stat-value">@(result?.Rows.Count ?? 0)</p>
            <p class="muted mt-1">From stored procedure</p>
        </div>
        <div class="stat-card">
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" />
            </svg>
            <p class="stat-label">Columns</p>
            <p class="stat-value">@(result?.Columns.Count ?? 0)</p>
            <p class="muted mt-1">Detected fields</p>
        </div>
        <div class="stat-card">
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <p class="stat-label">Status</p>
            <p class="stat-value">@(string.IsNullOrWhiteSpace(loadError) ? "Ready" : "Error")</p>
            <p class="muted mt-1">Connectivity</p>
        </div>
    </div>

    <div class="space-y-4">
        @if (!string.IsNullOrWhiteSpace(lastUpdated))
        {
            <div class="surface">
                <p class="text-sm font-bold text-heading">Last Updated: @lastUpdated</p>
            </div>
        }

        @if (dbCards.Count > 0)
        {
            <div class="space-y-4">
                @foreach (var card in dbCards)
                {
                    <div class="surface">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <svg class="w-5 h-5 icon-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                                </svg>
                                <h3 class="text-base font-bold text-heading">@card.Name</h3>
                            </div>
                            <p class="text-xs text-body-secondary">@card.Rows.Count rows</p>
                        </div>
                        <div class="db-grid__wrap">
                            <table class="db-grid">
                                <thead>
                                    <tr>
                                        @foreach (var column in card.Columns)
                                        {
                                            <th class="db-grid__head @GetColumnAlignmentClass(column)">@ToHeaderLabel(column)</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in card.Rows)
                                    {
                                        var alertIndex = GetAlertColumnIndex(card.Columns);
                                        var rowAlertClass = alertIndex >= 0 ? GetAlertLevelClass(row[alertIndex]) : string.Empty;
                                        <tr class="db-grid__row @rowAlertClass">
                                            @for (var i = 0; i < row.Count; i++)
                                            {
                                                @if (IsAlertLevelColumn(card.Columns[i]))
                                                {
                                                    var badgeClass = GetAlertLevelClass(row[i]);
                                                    <td class="db-grid__cell @GetColumnAlignmentClass(card.Columns[i])">
                                                        <span class="alert-badge @badgeClass">@FormatCellValue(row[i], card.Columns[i])</span>
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td class="db-grid__cell @GetColumnAlignmentClass(card.Columns[i])">
                                                        @FormatCellValue(row[i], card.Columns[i])
                                                    </td>
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!isLoading && string.IsNullOrWhiteSpace(loadError) && result is not null && result.Rows.Count > 0)
        {
            <div class="surface">
                <p class="muted">Database cards are unavailable because the DatabaseName column was not found.</p>
            </div>
        }

        @if (isLoading)
        {
            <div class="surface">
                <p class="muted">Loading data from SQL Server...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="surface !border-rose-500/30">
                <p class="text-sm font-semibold text-error">Failed to load monitoring data.</p>
                <p class="mt-2 text-sm text-error/80">@loadError</p>
            </div>
        }
        else if (result is null || result.Rows.Count == 0)
        {
            <div class="surface">
                <p class="muted">No rows returned from the stored procedure.</p>
            </div>
        }
        else
        {
            <div class="surface">
                <p class="muted">Database cards are shown above.</p>
            </div>
        }
    </div>
</div>

